<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================= -->
    <!-- PERMISOS DE ALMACENAMIENTO                    -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- ============================================= -->
    <!-- PERMISOS USB HOST (OTG)                      -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />
    <uses-feature android:name="android.hardware.usb.host" android:required="true" />

    <!-- ============================================= -->
    <!-- PERMISOS DE RED                              -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- ============================================= -->
    <!-- PERMISOS DE SISTEMA                          -->
    <!-- ============================================= -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Para detección de dispositivos en modo download/fastboot -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE"
        android:maxSdkVersion="32" />

    <application
        android:name=".TerminalMasterHubApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Terminal Master Hub"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TerminalMasterHub"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">

        <!-- Actividad principal con Bottom Navigation -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad para renderizado gráfico de Python -->
        <activity
            android:name=".ui.terminal.PythonGraphActivity"
            android:exported="false"
            android:theme="@style/Theme.TerminalMasterHub.Dialog"
            android:windowSoftInputMode="adjustNothing" />

        <!-- Servicio foreground para flasheo en segundo plano -->
        <service
            android:name=".core.usb.FlashForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Filtros de detección USB para ADB/Fastboot -->
        <activity
            android:name=".ui.fastboot.UsbDeviceActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.TerminalMasterHub.Dialog">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <!-- Filtro de detección USB para Samsung Download Mode -->
        <activity
            android:name=".ui.samsung.SamsungUsbActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.TerminalMasterHub.Dialog">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/samsung_device_filter" />
        </activity>

        <!-- Broadcast Receiver para manejo de eventos USB -->
        <receiver
            android:name=".core.usb.UsbBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
                <action android:name="com.terminalmasterhub.USB_PERMISSION" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
