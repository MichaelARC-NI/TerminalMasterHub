<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:fitsSystemWindows="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg_dark">

    <LinearLayout
        android:id="@+id/samsungToolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/terminal_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Samsung Odin3 (Download Mode)"
            android:textColor="@color/session_samsung"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/samsungDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:text="@string/samsung_no_device"
            android:textColor="@color/terminal_red"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Área de selección de archivos -->
    <LinearLayout
        android:id="@+id/samsungFileSelector"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/samsungToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Firmware (ODIN)"
            android:textColor="@color/terminal_amber"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/border_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/samsungFilePath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:singleLine="true"
                android:text="Ningún archivo seleccionado"
                android:textColor="@color/terminal_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnSamsungBrowse"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Examinar"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Controles de flasheo -->
    <LinearLayout
        android:id="@+id/samsungActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/samsungFileSelector"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSamsungFlash"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/samsung_flash"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSamsungReboot"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/samsung_reboot"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Opciones avanzadas -->
    <LinearLayout
        android:id="@+id/samsungOptions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/samsungActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <CheckBox
            android:id="@+id/chkSamsungAutoReboot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Auto Reboot después de flashear"
            android:textColor="@color/terminal_text"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/chkSamsungMd5Check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Verificar MD5 antes de flashear"
            android:textColor="@color/terminal_text"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/chkSamsungUserdata"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:text="Wipe Userdata"
            android:textColor="@color/terminal_red"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Log de flasheo -->
    <TextView
        android:id="@+id/samsungLogLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:text="Log de flasheo:"
        android:textColor="@color/terminal_amber"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/samsungOptions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/samsungLogScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@color/terminal_bg"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/samsungLogLabel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/samsungLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/terminal_text"
            android:textSize="11sp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
