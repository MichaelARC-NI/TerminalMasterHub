<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg_dark">

    <LinearLayout
        android:id="@+id/fastbootToolbar"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:background="@color/terminal_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fastboot — Bootloader &amp; Flasheo"
            android:textColor="@color/session_fastboot"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fastbootDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:text="@string/fastboot_no_device"
            android:textColor="@color/terminal_red"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Controles Fastboot -->
    <LinearLayout
        android:id="@+id/fastbootControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/fastbootToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnFastbootDevices"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="devices"
            android:textSize="10sp"
            android:paddingHorizontal="8dp" />

        <Button
            android:id="@+id/btnFastbootGetvar"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="getvar"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:layout_marginStart="2dp" />

        <Button
            android:id="@+id/btnFastbootFlash"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="flash"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:layout_marginStart="2dp" />

        <Button
            android:id="@+id/btnFastbootOem"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="oem"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:layout_marginStart="2dp" />

        <Button
            android:id="@+id/btnFastbootReboot"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="reboot"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- Log de salida -->
    <ScrollView
        android:id="@+id/fastbootLogScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/terminal_bg"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/fastbootControls"
        app:layout_constraintBottom_toTopOf="@id/fastbootInputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/fastbootLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/terminal_text"
            android:textSize="11sp" />
    </ScrollView>

    <!-- Barra de entrada -->
    <LinearLayout
        android:id="@+id/fastbootInputBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="@color/terminal_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="fastboot&gt; "
            android:textColor="@color/session_fastboot"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <EditText
            android:id="@+id/fastbootInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/fastboot_send_command"
            android:textColor="@color/terminal_text"
            android:textColorHint="@color/divider"
            android:textSize="13sp"
            android:singleLine="true"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/btnFastbootSend"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_usb"
            android:contentDescription="Enviar comando fastboot" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
