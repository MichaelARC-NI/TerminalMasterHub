<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg_dark">

    <!-- Barra de estado ADB -->
    <LinearLayout
        android:id="@+id/adbStatusBar"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:background="@color/terminal_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ADB Shell Interactivo"
            android:textColor="@color/session_fastboot"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adbDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:text="Desconectado"
            android:textColor="@color/terminal_red"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Botones rápidos ADB -->
    <LinearLayout
        android:id="@+id/adbControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/adbStatusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAdbDevices"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="devices"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnAdbShell"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="adb shell"
            android:textSize="11sp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnAdbPush"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="push"
            android:textSize="11sp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btnAdbPull"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="pull"
            android:textSize="11sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Log de salida ADB -->
    <ScrollView
        android:id="@+id/adbLogScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/terminal_bg"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/adbControls"
        app:layout_constraintBottom_toTopOf="@id/adbInputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/adbLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/terminal_text"
            android:textSize="11sp" />
    </ScrollView>

    <!-- Barra de entrada ADB -->
    <LinearLayout
        android:id="@+id/adbInputBar"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="@color/terminal_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="adb&gt; "
            android:textColor="@color/session_fastboot"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <EditText
            android:id="@+id/adbInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="shell, devices, push, pull..."
            android:textColor="@color/terminal_text"
            android:textColorHint="@color/divider"
            android:textSize="13sp"
            android:singleLine="true"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/btnAdbSend"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_adb"
            android:contentDescription="Enviar comando ADB" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
