<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme: Dark terminal-style -->
    <style name="Theme.TerminalMasterHub" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/terminal_green</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/terminal_amber</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/terminal_bg</item>
        <item name="colorOnSurface">@color/terminal_text</item>
        <item name="android:statusBarColor">@color/terminal_bg_dark</item>
        <item name="android:navigationBarColor">@color/terminal_bg_dark</item>
    </style>

    <!-- Dialog theme for Python graph rendering -->
    <style name="Theme.TerminalMasterHub.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="colorPrimary">@color/terminal_green</item>
        <item name="colorSurface">@color/terminal_bg</item>
        <item name="colorOnSurface">@color/terminal_text</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@color/terminal_bg_dark</item>
    </style>
</resources>
